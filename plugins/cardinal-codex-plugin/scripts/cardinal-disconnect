#!/usr/bin/env python3
"""Disconnect Codex from Cardinal."""

from __future__ import annotations

import argparse
import json
import re
import sys
import time
import tomllib
import urllib.error
import urllib.request
from pathlib import Path


CODEX_DIR = Path.home() / ".codex"
CONFIG_PATH = CODEX_DIR / "config.toml"
HOOKS_PATH = CODEX_DIR / "hooks.json"
STATE_PATH = CODEX_DIR / "cardinal.json"
SECRETS_PATH = CODEX_DIR / "cardinal-secrets.json"
# Plugin-owned runtime state: telemetry progress cursors, the plan stamp,
# and spend-limits verdict/ack/override files.
RUNTIME_DIR = CODEX_DIR / "cardinal"
MCP_SERVER_NAME = "cardinal"

BEGIN_MARKER = "# BEGIN cardinal-codex-plugin managed MCP server"
END_MARKER = "# END cardinal-codex-plugin managed MCP server"


def atomic_write(path: Path, content: str) -> None:
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_text(content)
    tmp.replace(path)


def backup(path: Path) -> Path | None:
    if not path.exists():
        return None
    ts = time.strftime("%Y%m%d-%H%M%S")
    target = path.with_suffix(f"{path.suffix}.bak.{ts}")
    target.write_text(path.read_text())
    return target


def load_json(path: Path) -> dict:
    if not path.exists():
        return {}
    try:
        data = json.loads(path.read_text())
    except Exception as exc:
        sys.exit(f"Refusing to proceed: {path} is unreadable ({exc})")
    if not isinstance(data, dict):
        sys.exit(f"Refusing to proceed: {path} is not a JSON object.")
    return data


def load_config() -> dict:
    if not CONFIG_PATH.exists():
        return {}
    try:
        return tomllib.loads(CONFIG_PATH.read_text())
    except Exception:
        return {}


def read_mcp_plaintext_from_config() -> str | None:
    config = load_config()
    servers = config.get("mcp_servers")
    if not isinstance(servers, dict):
        return None
    entry = servers.get(MCP_SERVER_NAME)
    if not isinstance(entry, dict):
        return None
    headers = entry.get("http_headers")
    if not isinstance(headers, dict):
        return None
    key = headers.get("X-CardinalHQ-API-Key")
    return key if isinstance(key, str) and key else None


def read_secrets() -> dict:
    return load_json(SECRETS_PATH) if SECRETS_PATH.exists() else {}


_ANY_TABLE_HEADER_RE = re.compile(r"^\s*\[")
_CARDINAL_TABLE_HEADER_RE = re.compile(
    r'^\s*\[mcp_servers\.(?:"cardinal"|cardinal)(?:\]|\.)'
)


def strip_managed_block(text: str) -> tuple[str, bool]:
    """Remove the plugin-managed Cardinal MCP config from config.toml.

    The BEGIN/END markers are ADVISORY, not a deletion span: Codex rewrites
    config.toml itself and can move its own sections (e.g. [desktop],
    [hooks.state]) inside the marker span (issue #10). Removal is therefore
    parse-aware — only the marker comment lines and the
    [mcp_servers.cardinal] table (header through the line before the next
    table header), wherever they sit, are removed. Foreign content that
    drifted between the markers is preserved verbatim.

    The BEGIN marker still gates the whole operation: without it the file
    is considered unmanaged and returned untouched, so a hand-written
    [mcp_servers.cardinal] table is never deleted.

    Keep this function in lockstep with cardinal-connect.
    """
    if BEGIN_MARKER not in text:
        return text, False
    out: list[str] = []
    in_cardinal = False
    for line in text.splitlines(keepends=True):
        stripped = line.strip()
        if stripped.startswith(BEGIN_MARKER) or stripped.startswith(END_MARKER):
            continue
        if in_cardinal:
            if _ANY_TABLE_HEADER_RE.match(line):
                in_cardinal = False  # table ended; fall through for this line
            else:
                continue
        if _CARDINAL_TABLE_HEADER_RE.match(line):
            in_cardinal = True
            continue
        out.append(line)
    new_text = re.sub(r"\n{3,}", "\n\n", "".join(out)).strip("\n")
    return (new_text + "\n" if new_text else ""), True


def remove_config_block() -> bool:
    if not CONFIG_PATH.exists():
        return False
    text = CONFIG_PATH.read_text()
    new_text, removed = strip_managed_block(text)
    if removed:
        backup_path = backup(CONFIG_PATH)
        atomic_write(CONFIG_PATH, new_text)
        print(f"Removed managed Cardinal MCP block from {CONFIG_PATH}")
        if backup_path:
            print(f"Backup: {backup_path}")
    return removed


def strip_managed_hooks(data: dict) -> tuple[dict, bool]:
    hooks = data.get("hooks")
    if not isinstance(hooks, dict):
        return data, False
    changed = False
    for event_name, groups in list(hooks.items()):
        if not isinstance(groups, list):
            continue
        kept_groups = []
        for group in groups:
            if not isinstance(group, dict):
                kept_groups.append(group)
                continue
            handlers = group.get("hooks")
            if not isinstance(handlers, list):
                kept_groups.append(group)
                continue
            kept_handlers = []
            for handler in handlers:
                if isinstance(handler, dict) and "cardinal-codex-plugin" in str(handler.get("command") or ""):
                    changed = True
                    continue
                kept_handlers.append(handler)
            if kept_handlers:
                new_group = dict(group)
                new_group["hooks"] = kept_handlers
                kept_groups.append(new_group)
        if kept_groups:
            hooks[event_name] = kept_groups
        else:
            hooks.pop(event_name, None)
    data["hooks"] = hooks
    return data, changed


def remove_hooks_config() -> bool:
    if not HOOKS_PATH.exists():
        return False
    data = load_json(HOOKS_PATH)
    new_data, changed = strip_managed_hooks(data)
    if changed:
        backup_path = backup(HOOKS_PATH)
        atomic_write(HOOKS_PATH, json.dumps(new_data, indent=2) + "\n")
        print(f"Removed managed Cardinal hooks from {HOOKS_PATH}")
        if backup_path:
            print(f"Hooks backup: {backup_path}")
    return changed


def revoke_key(host: str, key_id: str, plaintext: str | None) -> tuple[bool, str]:
    url = host.rstrip("/") + f"/api/maestro-keys/{key_id}/revoke"
    headers = {"content-type": "application/json"}
    if plaintext:
        headers["X-CardinalHQ-API-Key"] = plaintext
    req = urllib.request.Request(url, data=b"", method="POST", headers=headers)
    try:
        with urllib.request.urlopen(req, timeout=15) as resp:
            return resp.status in (200, 204), f"HTTP {resp.status}"
    except urllib.error.HTTPError as exc:
        return False, f"HTTP {exc.code}"
    except (urllib.error.URLError, TimeoutError) as exc:
        return False, f"network error: {exc}"


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="cardinal-disconnect",
        description="Disconnect Codex from Cardinal.",
    )
    parser.add_argument(
        "--force",
        action="store_true",
        help="Do not fail if ~/.codex/cardinal.json is missing.",
    )
    return parser.parse_args()


def main() -> int:
    args = parse_args()

    if not STATE_PATH.exists() and not args.force:
        print("Cardinal is not connected. Nothing to do.")
        return 0

    state = load_json(STATE_PATH)
    host = state.get("host") or "https://app.cardinalhq.io"
    secrets = read_secrets()
    mcp_key_id = state.get("mcp_key_id")
    ingest_key_id = state.get("ingest_key_id")

    if ingest_key_id:
        plaintext = secrets.get("ingest_api_key")
        ok, msg = revoke_key(host, ingest_key_id, plaintext if isinstance(plaintext, str) else None)
        if ok:
            print(f"Revoked ingest key {state.get('ingest_key_prefix') or ingest_key_id} server-side ({msg})")
        else:
            print(f"Could not revoke ingest key server-side ({msg}).")
            print(f"Visit {host}/settings/api-keys to revoke it manually.")

    if mcp_key_id:
        plaintext = read_mcp_plaintext_from_config() or secrets.get("mcp_api_key")
        ok, msg = revoke_key(host, mcp_key_id, plaintext if isinstance(plaintext, str) else None)
        if ok:
            print(f"Revoked MCP key {state.get('mcp_key_prefix') or mcp_key_id} server-side ({msg})")
        else:
            print(f"Could not revoke MCP key server-side ({msg}).")
            print(f"Visit {host}/settings/api-keys to revoke it manually.")

    removed = remove_config_block()
    if not removed:
        print(f"No managed Cardinal MCP block found in {CONFIG_PATH}")

    removed_hooks = remove_hooks_config()
    if not removed_hooks:
        print(f"No managed Cardinal hooks found in {HOOKS_PATH}")

    if SECRETS_PATH.exists():
        SECRETS_PATH.unlink()
        print(f"Removed {SECRETS_PATH}")

    if STATE_PATH.exists():
        STATE_PATH.unlink()
        print(f"Removed {STATE_PATH}")

    if RUNTIME_DIR.exists():
        import shutil

        shutil.rmtree(RUNTIME_DIR, ignore_errors=True)
        print(f"Removed {RUNTIME_DIR}")

    print()
    print("Restart Codex so it reloads MCP and hook configuration.")
    return 0


if __name__ == "__main__":
    sys.exit(main())
