#!/usr/bin/env python3
"""cardinal-status — verify the Cardinal Codex plugin's wiring.

Reads the (full-key) state at ~/.codex/cardinal.json and reports both
sides depending on the recorded mode. Cross-checks ~/.codex/config.toml
(the [otel] block + [mcp_servers.cardinal] entry, plus the [hooks.state]
entries Codex records when it auto-registers the plugin's hooks), then
probes both endpoints for reachability.

Unlike the Claude version, the ingest key lives in cardinal.json itself
(Codex has no settings.json env block). New Cardinal MCP registrations
also keep the MCP key in cardinal.json and in config.toml http_headers;
legacy registrations may still point Codex at CARDINAL_MCP_API_KEY.
"""

import json
import re
import sys
import urllib.error
import urllib.request
from datetime import datetime, timezone
from pathlib import Path


CODEX_DIR = Path.home() / ".codex"
CONFIG_PATH = CODEX_DIR / "config.toml"
STATE_PATH = CODEX_DIR / "cardinal.json"
MCP_API_HEADER = "x-cardinalhq-api-key"
LEGACY_MCP_KEY_ENV_VAR = "CARDINAL_MCP_API_KEY"


def load_or_die(path: Path, label: str) -> dict:
    if not path.exists():
        return {}
    try:
        return json.loads(path.read_text())
    except Exception as e:
        print(f"✗ {label} ({path}) is unreadable: {e}")
        sys.exit(1)


def load_toml(path: Path) -> dict:
    """Best-effort TOML read for cross-checks. tomllib (3.11+) when present;
    otherwise a tolerant header scan returning {table: {}} so presence
    checks still work. Never raises — status is informational."""
    if not path.exists():
        return {}
    raw = path.read_text()
    if not raw.strip():
        return {}
    try:
        import tomllib
        return tomllib.loads(raw)
    except ModuleNotFoundError:
        pass
    except Exception:
        return {}
    out: dict = {}
    cur = None
    for line in raw.splitlines():
        s = line.strip()
        if s.startswith("[") and s.endswith("]") and not s.startswith("[["):
            header = s[1:-1].strip()
            cur = out
            parts = [p.strip().strip('"') for p in header.split(".")]
            for part in parts:
                cur = cur.setdefault(part, {})
    return out


def probe_ingest(endpoint: str, key: str) -> str:
    url = endpoint.rstrip("/") + "/v1/metrics"
    req = urllib.request.Request(
        url,
        data=b"",
        method="POST",
        headers={"content-type": "application/x-protobuf",
                 "x-cardinalhq-api-key": key},
    )
    try:
        with urllib.request.urlopen(req, timeout=10) as resp:
            return f"✓ Ingest reachable (HTTP {resp.status})"
    except urllib.error.HTTPError as e:
        if e.code in (401, 403):
            return f"✗ Ingest returned HTTP {e.code} — key invalid or revoked. Run /cardinal:connect --rotate."
        return f"✓ Ingest reachable (HTTP {e.code} on empty body — expected)"
    except (urllib.error.URLError, TimeoutError) as e:
        return f"✗ Ingest network error: {e}"


def probe_mcp(mcp_url: str, key: str, header_name: str = MCP_API_HEADER) -> str:
    req = urllib.request.Request(
        mcp_url,
        method="GET",
        headers={header_name: key},
    )
    try:
        with urllib.request.urlopen(req, timeout=10) as resp:
            return f"✓ MCP reachable (HTTP {resp.status})"
    except urllib.error.HTTPError as e:
        if e.code in (401, 403):
            return f"✗ MCP returned HTTP {e.code} — key invalid or revoked. Run /cardinal:connect --rotate."
        return f"✓ MCP reachable (HTTP {e.code} — auth OK)"
    except (urllib.error.URLError, TimeoutError) as e:
        return f"✗ MCP network error: {e}"


_HOOK_STATE_RE = re.compile(
    r'^\s*\[hooks\.state\."cardinal@[^"]*:hooks/hooks\.json:[^"]*"\]\s*$'
)


def _cardinal_hook_count() -> int:
    """Count the plugin's auto-registered hooks. Codex discovers the plugin's
    hooks/hooks.json on its own and tracks each entry in config.toml under
    [hooks.state."cardinal@<marketplace>:hooks/hooks.json:..."]; connect does
    NOT write to ~/.codex/hooks.json. We count those state headers."""
    if not CONFIG_PATH.exists():
        return 0
    try:
        raw = CONFIG_PATH.read_text()
    except Exception:
        return 0
    return sum(1 for line in raw.splitlines() if _HOOK_STATE_RE.match(line))


def _header_value(headers: object, header_name: str) -> "str | None":
    if not isinstance(headers, dict):
        return None
    wanted = header_name.lower()
    for key, value in headers.items():
        if isinstance(key, str) and key.lower() == wanted and isinstance(value, str):
            return value
    return None


def main() -> int:
    if not STATE_PATH.exists():
        print("✗ Not connected. Run /cardinal:connect to wire up.")
        return 1

    state = load_or_die(STATE_PATH, "cardinal.json")
    mode = state.get("mode", "unknown")
    print(f"  Mode:        {mode}")
    print(f"  Runtime:     {state.get('runtime', 'codex')}")
    print(f"  User:        {state.get('user_email')}")
    print(f"  Org:         {state.get('org_slug') or state.get('org_id')}")
    print(f"  Host:        {state.get('host')}")
    print(f"  Plugin ver:  {state.get('plugin_version')}")
    written_at = state.get("written_at")
    if written_at:
        try:
            t = datetime.fromisoformat(written_at.replace("Z", "+00:00"))
            age_days = (datetime.now(timezone.utc) - t).days
            print(f"  Connected:   {age_days} day(s) ago")
            if age_days >= 90:
                print("  ⚠  Connection is older than 90 days — consider /cardinal:connect --rotate")
        except Exception:
            pass

    config = load_toml(CONFIG_PATH)
    mcp_servers = config.get("mcp_servers", {}) if isinstance(config.get("mcp_servers"), dict) else {}

    # ---- Telemetry side --------------------------------------------------
    telemetry_enabled = state.get("telemetry", {}).get("enabled", True)
    if telemetry_enabled:
        print()
        print(f"  Telemetry endpoint:   {state.get('ingest_endpoint')}")
        print(f"  Ingest key prefix:    {state.get('ingest_key_prefix')}")
        tool_details = state.get("telemetry", {}).get("tool_details", False)
        if tool_details:
            print("  Tool details:         enabled")
        else:
            print("  Tool details:         disabled (Outcomes Dashboard will show repo=unknown, service=unknown)")

        if "otel" not in config:
            print("  ✗ [otel] block missing from config.toml. Run /cardinal:connect --rotate to repair.")
            return 1

        endpoint = state.get("ingest_endpoint")
        key = state.get("ingest_api_key") or ""
        if endpoint and key:
            print(f"  {probe_ingest(endpoint, key)}")

    # ---- MCP side --------------------------------------------------------
    mcp_url_state = state.get("mcp_url")
    if mcp_url_state:
        print()
        print(f"  MCP endpoint:         {mcp_url_state}")
        print(f"  MCP key prefix:       {state.get('mcp_key_prefix')}")

        cardinal_server = mcp_servers.get("cardinal") if isinstance(mcp_servers, dict) else None
        if not cardinal_server:
            print("  ✗ [mcp_servers.cardinal] missing from config.toml.")
            print("    Run /cardinal:connect --rotate to repair.")
            return 1
        config_url = cardinal_server.get("url") if isinstance(cardinal_server, dict) else None
        if config_url and config_url != mcp_url_state:
            print(f"  ⚠ config.toml mcp url differs from state ({config_url} vs {mcp_url_state}).")

        mcp_header_name = state.get("mcp_api_header") or MCP_API_HEADER
        mcp_key = state.get("mcp_api_key") or _header_value(
            cardinal_server.get("http_headers") if isinstance(cardinal_server, dict) else None,
            mcp_header_name,
        )

        import os as _os
        if mcp_key:
            print(f"  {probe_mcp(mcp_url_state, mcp_key, mcp_header_name)}")
        else:
            legacy_env_name = None
            if isinstance(cardinal_server, dict):
                legacy_env_name = cardinal_server.get("bearer_token_env_var")
            legacy_key = _os.environ.get(legacy_env_name or LEGACY_MCP_KEY_ENV_VAR)
            if legacy_key:
                print(f"  {probe_mcp(mcp_url_state, legacy_key, mcp_header_name)}")
            elif legacy_env_name:
                print(f"  ⚠ {legacy_env_name} not set; Codex will warn at startup.")
                print("    This is a legacy MCP registration. Run /cardinal:connect --rotate")
                print("    to rewrite it with config.toml http_headers.")
            else:
                print("  ✗ No MCP key found in cardinal.json or config.toml http_headers.")
                print("    Run /cardinal:connect --rotate to repair.")

    # ---- Hooks -----------------------------------------------------------
    n_hooks = _cardinal_hook_count()
    print()
    if n_hooks:
        print(f"  Hooks:                {n_hooks} cardinal hook(s) auto-registered by Codex")
    else:
        print("  ⚠ Codex hasn't auto-registered the plugin hooks "
              "(start a new thread; ensure the plugin is enabled and features.hooks is on).")

    # ---- Spend limits ----------------------------------------------------
    limits_state = state.get("limits")
    if isinstance(limits_state, dict) and limits_state.get("status_url"):
        print()
        print(f"  Limits endpoint:      {limits_state['status_url']}")
        try:
            sys.path.insert(
                0,
                str(Path(__file__).resolve().parent.parent / "hooks"),
            )
            import _limits_common as lc

            api_key = state.get("ingest_api_key")
            if not api_key:
                print("  ✗ No ingest key in cardinal.json — run /cardinal:connect --rotate.")
            else:
                import os as _os

                repo, branch = lc.git_facts(_os.getcwd())
                verdict = lc.fetch_status(
                    limits_state["status_url"],
                    api_key,
                    session_id="cardinal-status-probe",
                    repo=repo,
                    branch=branch,
                    timeout=5.0,
                )
                if verdict is None:
                    print("  ✗ Limits endpoint unreachable.")
                else:
                    lines = lc.standing_lines(verdict)
                    if lines:
                        print("  Budget standing:")
                        for line in lines:
                            print(f"    {line}")
                    else:
                        print("  ✓ Limits endpoint reachable — no spend limits configured for this org.")
        except Exception as e:  # standing is informational; never fail status over it
            print(f"  ✗ Limits check failed: {e}")

    print()
    print("If you haven't started a new Codex thread since connecting, do it now —")
    print("config.toml ([otel] + the MCP server) and the plugin's hooks are read")
    print("when a thread starts.")
    return 0


if __name__ == "__main__":
    sys.exit(main())
