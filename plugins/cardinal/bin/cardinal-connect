#!/usr/bin/env python3
"""cardinal-connect — wire Codex CLI up to Cardinal.

Runs the maestro device-code flow (cardinal-mcp-aggregator.md R5b) to
mint an ingest key (OTel telemetry to the Outcomes Dashboard) AND an
MCP key (unified `cardinal` MCP in this Codex session) in one
browser-approved consent. `--telemetry-only` opts out of the MCP side.

How the two surfaces wire up on Codex (v0.1 design):
  - Codex does NOT inject env into hook subprocesses and has no
    settings.json `env` block. So instead of an env overlay, connect
    writes a single state file — ~/.codex/cardinal.json — that the
    hooks read directly (via hooks/_codex_state.py) to learn where to
    POST telemetry and which resource attributes to stamp. This file
    holds the FULL ingest key (unlike the Claude state file, which kept
    only a prefix because the key lived in settings.json env). 0600.
  - The MCP server is registered in ~/.codex/config.toml with a direct
    http_headers entry carrying X-CardinalHQ-API-Key. Codex's `mcp add`
    CLI only exposes bearer-token env vars for HTTP servers, but the
    config schema supports http_headers and masks them in `codex mcp get`.
  - Codex's native OTel exporter is configured via an [otel] block in
    config.toml so Codex streams its own session/turn telemetry to
    Cardinal alongside the plugin hooks.
  - The plugin's hook entries are NOT registered by connect. Codex
    auto-registers the plugin's hooks/hooks.json directly (it tracks them
    in config.toml as `cardinal@<marketplace>:hooks/hooks.json:...`), so
    connect merging them into ~/.codex/hooks.json would double-fire every
    event. The template commands are `./hooks/*.py`, relative to the
    plugin root Codex runs them from.

Writes:
  ~/.codex/cardinal.json    full ingest+mcp state (0600)
  ~/.codex/config.toml      [otel] block + [mcp_servers.cardinal]
"""

import argparse
import json
import os
import socket
import sys
import time
import urllib.error
import urllib.request
from datetime import datetime, timezone
from pathlib import Path
from urllib.parse import urlparse


PLUGIN_VERSION = "0.1.0"  # keep in sync with .codex-plugin/plugin.json

CODEX_DIR = Path.home() / ".codex"
CONFIG_PATH = CODEX_DIR / "config.toml"
STATE_PATH = CODEX_DIR / "cardinal.json"
# Side-channel file that surfaces the verification URL while the
# polling loop blocks. Codex's shell tool buffers stdout until the
# command returns, so the URL printed to stdout never reaches the user
# in time. The SKILL.md tells Codex to run this bin in background and
# read the pending file within a few seconds — that's how the URL gets
# in front of the human. Cleared on every exit path via try/finally.
PENDING_PATH = CODEX_DIR / "cardinal-pending.json"

CLIENT_ID = "cardinal-codex-plugin"

# Header the Cardinal MCP aggregator accepts for the minted per-user key.
MCP_API_HEADER = "x-cardinalhq-api-key"

# config.toml top-level tables this plugin owns / removes on disconnect.
# Anything else in the user's config.toml is preserved verbatim.
OWNED_TOML_TABLES = {
    "otel",                    # Codex native OTel exporter
    "mcp_servers.cardinal",    # the cardinal MCP server
}

DEFAULT_POLL_TIMEOUT_SECS = 600
DEFAULT_POLL_INTERVAL_SECS = 5


# ---------------------------------------------------------------------------
# Misc helpers
# ---------------------------------------------------------------------------

def derive_deployment_env(host: str) -> str:
    try:
        hostname = urlparse(host).hostname or ""
    except Exception:
        return "unknown"
    if hostname == "app.cardinalhq.io":
        return "prod"
    if "dogfood" in hostname:
        return "dogfood"
    if "cardinalhq.io" in hostname:
        return "cardinal"
    return "customer"


def atomic_write(path: Path, content: str, mode: int | None = None) -> None:
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_text(content)
    if mode is None and path.exists():
        mode = path.stat().st_mode & 0o777
    if mode is not None:
        try:
            os.chmod(tmp, mode)
        except OSError:
            pass
    tmp.replace(path)


def write_pending(grant: dict) -> None:
    """Write the verification URL to a side-channel file so Codex can
    surface it to the user while the polling loop blocks. See PENDING_PATH
    docstring for the design rationale."""
    payload = {
        "verification_uri": grant.get("verification_uri", ""),
        "user_code": grant.get("user_code", ""),
        "expires_in": grant.get("expires_in", DEFAULT_POLL_TIMEOUT_SECS),
        "written_at": datetime.now(timezone.utc).isoformat(),
        "plugin_version": PLUGIN_VERSION,
    }
    PENDING_PATH.parent.mkdir(parents=True, exist_ok=True)
    atomic_write(PENDING_PATH, json.dumps(payload, indent=2) + "\n")


def clear_pending() -> None:
    """Remove the pending file. Idempotent — safe to call from finally even
    when write_pending was never reached (e.g. /code failed)."""
    try:
        PENDING_PATH.unlink()
    except FileNotFoundError:
        pass


# ---------------------------------------------------------------------------
# Device-code flow  (VERBATIM from the Claude reference)
# ---------------------------------------------------------------------------

def _post_json(url: str, body: dict, timeout: int = 15) -> tuple[int, dict | None]:
    payload = json.dumps(body).encode("utf-8")
    req = urllib.request.Request(
        url,
        data=payload,
        method="POST",
        headers={"content-type": "application/json"},
    )
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            raw = resp.read()
            return resp.status, json.loads(raw) if raw else None
    except urllib.error.HTTPError as e:
        raw = e.read() if hasattr(e, "read") else b""
        try:
            return e.code, json.loads(raw) if raw else None
        except json.JSONDecodeError:
            return e.code, None


def start_device_code(host: str, scopes: list[str]) -> dict:
    url = host.rstrip("/") + "/api/auth/device/code"
    status, body = _post_json(
        url,
        {
            "client": CLIENT_ID,
            "scopes": scopes,
            "hostname": socket.gethostname(),
        },
    )
    if status != 201 or not body:
        err = (body or {}).get("error", f"HTTP {status}")
        desc = (body or {}).get("error_description", "")
        sys.exit(f"device-code init failed: {err}{(' — ' + desc) if desc else ''}")
    return body


def poll_device_token(host: str, device_code: str, interval: int, timeout: int) -> dict:
    """Poll /token at the server's recommended interval until success, denied,
    or expired. Returns the success bundle. RFC 8628 error codes:
      - authorization_pending → keep polling
      - access_denied         → user denied; surface and exit
      - expired_token         → the grant TTL passed; tell the user to re-run
      - slow_down             → bump interval by 5s
      - invalid_grant         → anything else (consumed / unknown / mismatch)
    """
    url = host.rstrip("/") + "/api/auth/device/token"
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        status, body = _post_json(
            url,
            {"device_code": device_code, "client": CLIENT_ID},
            timeout=20,
        )
        body = body or {}
        if status == 200:
            return body
        err = body.get("error", f"http_{status}")
        if err == "authorization_pending":
            time.sleep(interval)
            continue
        if err == "slow_down":
            interval += 5
            time.sleep(interval)
            continue
        if err == "access_denied":
            sys.exit("✗ Request was denied in the browser.")
        if err == "expired_token":
            sys.exit("✗ Consent request expired before approval. Re-run /cardinal:connect.")
        desc = body.get("error_description", "")
        sys.exit(f"✗ device-code failed: {err}{(' — ' + desc) if desc else ''}")
    sys.exit("✗ Timed out waiting for browser approval. Re-run /cardinal:connect.")


# ---------------------------------------------------------------------------
# Reachability  (VERBATIM from the Claude reference)
# ---------------------------------------------------------------------------

# Backoff schedule for the ingest 401 retry. The device-code /token mints
# the local ingest row and enqueues a `provision_ingest_key` sync job whose
# worker calls Lakerunner's importApiKey to push the plaintext. There's a
# ~1-2 s window where the bundle is back to the plugin but the worker
# hasn't finished pushing, during which the key 401s at the OTLP intake.
# These sleeps cover up to ~60 s of propagation, leaving headroom for
# slower clusters or transient Lakerunner-side replication delays.
_INGEST_PROBE_RETRY_SLEEPS = (1.0, 2.0, 4.0, 8.0, 15.0, 30.0)


def _ingest_probe_once(endpoint: str, key: str) -> tuple[bool, str]:
    """One probe attempt — no retries. Used internally by
    verify_ingest_reachable and exposed via _override_ for tests."""
    url = endpoint.rstrip("/") + "/v1/metrics"
    req = urllib.request.Request(
        url,
        data=b"",
        method="POST",
        headers={"content-type": "application/x-protobuf",
                 "x-cardinalhq-api-key": key},
    )
    try:
        with urllib.request.urlopen(req, timeout=10) as resp:
            return (resp.status not in (401, 403), f"HTTP {resp.status}")
    except urllib.error.HTTPError as e:
        if e.code in (401, 403):
            return False, f"HTTP {e.code} — key invalid"
        if e.code < 500:
            return True, f"HTTP {e.code} on empty body — auth OK"
        return False, f"HTTP {e.code}"
    except (urllib.error.URLError, TimeoutError) as e:
        return False, f"network error: {e}"


def verify_ingest_reachable(endpoint: str | None, key: str | None) -> tuple[bool, str]:
    # Defensive null guards — v1.52.0-rc3 fails /token with 503 on the
    # server side when MAESTRO_INGEST_ENDPOINT is unset, but older
    # deployments or any future bug producing a malformed bundle would
    # crash this function with None.rstrip(). Surface a clear
    # operator-misconfig message instead of a Python traceback.
    if not endpoint:
        return False, (
            "server returned no ingest endpoint — likely operator misconfig "
            "(MAESTRO_INGEST_ENDPOINT unset on the Cardinal host)"
        )
    if not key:
        return False, "server returned no ingest key"

    # Retry on 401 only. Other failure modes (network, 5xx, etc.) are not
    # the propagation race we're papering over — surface immediately so
    # they don't get masked behind a 60 s wait.
    last_msg = ""
    for attempt in range(len(_INGEST_PROBE_RETRY_SLEEPS) + 1):
        ok, msg = _ingest_probe_once(endpoint, key)
        if ok:
            return ok, msg
        last_msg = msg
        if "HTTP 401" not in msg:
            return ok, msg
        if attempt < len(_INGEST_PROBE_RETRY_SLEEPS):
            sleep_s = _INGEST_PROBE_RETRY_SLEEPS[attempt]
            print(
                f"  … ingest key 401s; the provision_ingest_key worker may "
                f"still be pushing it to Lakerunner. Retrying in {sleep_s:.0f}s "
                f"(attempt {attempt + 2}/{len(_INGEST_PROBE_RETRY_SLEEPS) + 1})…"
            )
            time.sleep(sleep_s)
    total = sum(_INGEST_PROBE_RETRY_SLEEPS)
    return False, (
        f"{last_msg} after {len(_INGEST_PROBE_RETRY_SLEEPS) + 1} attempts "
        f"over ~{total:.0f}s. The ingest key was minted locally but never "
        f"propagated to Lakerunner — check the provision_ingest_key sync "
        f"job on the Cardinal server."
    )


def verify_mcp_reachable(
    mcp_url: str | None,
    key: str | None,
    header_name: str = MCP_API_HEADER,
) -> tuple[bool, str]:
    """Blind GET to the MCP URL with the per-user key. We want a non-401/403
    response; the aggregator only speaks JSON-RPC over POST so a GET will
    likely 405/406 — that's fine, the goal is to confirm auth clears."""
    # Same defensive guard as verify_ingest_reachable — surface "server
    # returned no MCP URL/key" instead of a Python traceback on a
    # malformed bundle.
    if not mcp_url:
        return False, "server returned no MCP URL"
    if not key:
        return False, "server returned no MCP key"
    req = urllib.request.Request(
        mcp_url,
        method="GET",
        headers={header_name: key},
    )
    try:
        with urllib.request.urlopen(req, timeout=10) as resp:
            return (resp.status not in (401, 403), f"HTTP {resp.status}")
    except urllib.error.HTTPError as e:
        if e.code in (401, 403):
            return False, f"HTTP {e.code} — MCP key invalid"
        return True, f"HTTP {e.code} (auth OK)"
    except (urllib.error.URLError, TimeoutError) as e:
        return False, f"network error: {e}"


# ---------------------------------------------------------------------------
# config.toml — read (tomllib if available, else tolerant fallback) + write
# ---------------------------------------------------------------------------

def _load_toml(path: Path) -> dict:
    """Read a TOML file into a dict. Uses tomllib (3.11+) when available;
    falls back to a tolerant line parser sufficient for our merge needs.
    Returns {} if the file is absent. The fallback only needs to identify
    which top-level tables exist so we don't clobber them — we never
    re-emit the user's content, we preserve their raw text (see
    write_config_toml)."""
    if not path.exists():
        return {}
    raw = path.read_text()
    if not raw.strip():
        return {}
    try:
        import tomllib  # py311+
        return tomllib.loads(raw)
    except ModuleNotFoundError:
        pass
    except Exception:
        # Malformed TOML — surface rather than silently clobbering.
        sys.exit(
            f"refusing to write: {path} is not valid TOML. "
            f"Back up the file, fix the syntax, then re-run."
        )
    # Tolerant fallback: we don't need full parsing, only the set of
    # top-level table headers present so the text-merge can decide whether
    # to replace or append. Return a shallow {table: {}} map.
    out: dict = {}
    for line in raw.splitlines():
        s = line.strip()
        if s.startswith("[") and s.endswith("]") and not s.startswith("[["):
            header = s[1:-1].strip()
            top = header.split(".", 1)[0].strip().strip('"')
            out.setdefault(top, {})
    return out


def _toml_escape(s: str) -> str:
    return s.replace("\\", "\\\\").replace('"', '\\"')


def _emit_otel_block(ingest_endpoint: str, deployment_env: str,
                     header_name: str, key: str) -> str:
    """Hand-rolled [otel] block. Codex uses the standard opentelemetry-otlp
    Rust exporter; the OtelExporterKind 'otlp-http' struct carries
    endpoint/protocol/tls. We also write a `headers` table (best-effort —
    see the connect docstring / verification notes; if Codex ignores it,
    auth must come from OTEL_EXPORTER_OTLP_HEADERS in the user's shell)."""
    return (
        "[otel]\n"
        f'environment = "{_toml_escape(deployment_env)}"\n'
        "log_user_prompt = false\n"
        "exporter = { otlp-http = { "
        f'endpoint = "{_toml_escape(ingest_endpoint)}", '
        'protocol = "binary", '
        f'headers = {{ "{_toml_escape(header_name)}" = "{_toml_escape(key)}" }}'
        " } }\n"
    )


def _emit_mcp_block(mcp_url: str, header_name: str, key: str) -> str:
    """Hand-rolled [mcp_servers.cardinal] block using Codex's supported
    direct HTTP headers schema (verified against the codex 0.141.x binary)."""
    return (
        "[mcp_servers.cardinal]\n"
        f'url = "{_toml_escape(mcp_url)}"\n'
        f'http_headers = {{ "{_toml_escape(header_name)}" = "{_toml_escape(key)}" }}\n'
    )


def _strip_toml_table(raw: str, header: str) -> str:
    """Remove a single TOML table (the `[header]` line and every line up to
    the next table header or EOF) from raw text, preserving everything else
    verbatim. `header` is the exact bracket contents, e.g.
    'otel' or 'mcp_servers.cardinal'."""
    lines = raw.splitlines(keepends=True)
    out: list[str] = []
    skipping = False
    for line in lines:
        s = line.strip()
        is_header = s.startswith("[") and s.endswith("]")
        if is_header:
            inner = s[1:-1].strip()
            if s.startswith("[["):
                inner = s[2:-2].strip()
            if inner == header:
                skipping = True
                continue
            # A different table header ends any skip region.
            skipping = False
        if skipping:
            continue
        out.append(line)
    return "".join(out)


def write_config_toml(blocks: dict[str, str]) -> None:
    """Merge the given owned tables into ~/.codex/config.toml, preserving all
    unrelated content verbatim. `blocks` maps a table header (e.g. 'otel',
    'mcp_servers.cardinal') to its full rendered text (header line included).

    Strategy: read the raw text, strip any prior copy of each owned table
    (text-level, so we never reserialize the user's config and risk
    dropping comments/formatting), then append the fresh blocks at the end.
    Validated for parse-ability afterward via _load_toml on the result is
    skipped intentionally — we only mutate our own tables."""
    raw = CONFIG_PATH.read_text() if CONFIG_PATH.exists() else ""
    # Validate the existing file parses before we touch it.
    _load_toml(CONFIG_PATH)

    for header in blocks:
        raw = _strip_toml_table(raw, header)

    if raw and not raw.endswith("\n"):
        raw += "\n"

    parts = [raw.rstrip("\n")] if raw.strip() else []
    for header, text in blocks.items():
        parts.append(text.rstrip("\n"))
    merged = "\n\n".join(p for p in parts if p) + "\n"

    CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
    atomic_write(CONFIG_PATH, merged, mode=0o600)


def add_mcp_server(mcp_url: str, header_name: str, key: str) -> str:
    """Register the cardinal MCP server.

    Codex's CLI cannot add direct HTTP headers for streamable HTTP MCP
    servers, so write the supported config table ourselves.
    """
    write_config_toml({
        "mcp_servers.cardinal": _emit_mcp_block(mcp_url, header_name, key),
    })
    return "config"


# ---------------------------------------------------------------------------
# State file  (~/.codex/cardinal.json — full key, 0600)
# ---------------------------------------------------------------------------

def build_resource_attributes(
    bundle: dict, deployment_env: str,
) -> str:
    org = bundle.get("org", {})
    user = bundle.get("user", {})
    return ",".join([
        "service.name=codex",
        "agent.runtime=codex",
        f"deployment.environment={deployment_env}",
        f"user.email={user.get('email') or 'unknown'}",
        f"cardinal.org={org.get('slug') or org.get('id') or 'unknown'}",
        f"cardinal.plugin_version={PLUGIN_VERSION}",
    ])


def write_state(
    bundle: dict,
    host: str,
    deployment_env: str,
    capture_tool_details: bool,
    telemetry_only: bool,
) -> None:
    org = bundle.get("org", {})
    user = bundle.get("user", {})
    mcp = bundle.get("mcp")
    ingest = bundle.get("ingest")
    mode = (
        "telemetry-only" if telemetry_only or mcp is None
        else "mcp-only" if ingest is None
        else "telemetry-and-mcp"
    )
    state = {
        "schema_version": 1,
        "host": host,
        "mode": mode,
        "runtime": "codex",
        "org_id": org.get("id"),
        "org_slug": org.get("slug"),
        "user_email": user.get("email"),
        "deployment_environment": deployment_env,
        "plugin_version": PLUGIN_VERSION,
        "written_at": datetime.now(timezone.utc).isoformat(),
        "telemetry": {
            "enabled": ingest is not None,
            "tool_details": capture_tool_details,
        },
    }
    if ingest:
        # The Codex state file holds the FULL ingest key — the hooks POST
        # with it directly (no settings.json env to carry it). 0600.
        header_name = ingest.get("api_header") or "x-cardinalhq-api-key"
        api_key = ingest.get("api_key") or ""
        state["ingest_endpoint"] = ingest["endpoint"]
        state["ingest_api_header"] = header_name
        state["ingest_api_key"] = api_key
        state["ingest_key_id"] = ingest.get("key_id")
        state["ingest_key_prefix"] = api_key[:8]
        state["resource_attributes"] = build_resource_attributes(bundle, deployment_env)
    if mcp:
        header_name = mcp.get("api_header") or MCP_API_HEADER
        api_key = mcp.get("api_key") or ""
        state["mcp_url"] = mcp["url"]
        state["mcp_api_header"] = header_name
        state["mcp_api_key"] = api_key
        state["mcp_key_id"] = mcp.get("key_id")
        state["mcp_key_prefix"] = mcp.get("key_prefix") or api_key[:8]
        state["mcp_created_at"] = mcp.get("created_at")
    # Spend-limits discovery (conductor docs/specs/agent-spend-limits.md).
    # When the bundle carries a limits block, the hooks poll status_url
    # with the ingest key on their turn cadence; absent (older maestro),
    # they do nothing limits-related.
    limits = bundle.get("limits")
    if isinstance(limits, dict) and limits.get("status_url"):
        state["limits"] = {
            "status_url": limits["status_url"],
            "enabled": bool(limits.get("enabled", True)),
        }
    STATE_PATH.parent.mkdir(parents=True, exist_ok=True)
    atomic_write(STATE_PATH, json.dumps(state, indent=2) + "\n", mode=0o600)
    try:
        os.chmod(STATE_PATH, 0o600)
    except OSError:
        pass


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main() -> int:
    # Line-buffer stdout so the approval URL surfaces the instant it's
    # printed, even when stdout is a pipe (Python block-buffers pipes by
    # default, which would hide the URL until the 10-min poll returns).
    try:
        sys.stdout.reconfigure(line_buffering=True)
    except Exception:
        pass

    p = argparse.ArgumentParser(
        prog="cardinal-connect",
        description=(
            "Connect Codex CLI to Cardinal — runs the device-code flow to "
            "enable telemetry (Outcomes Dashboard) AND the unified Cardinal MCP "
            "server in one consent. Use --telemetry-only to opt out of MCP."
        ),
    )
    p.add_argument(
        "--host", default="https://app.cardinalhq.io",
        help="Cardinal app host (default: https://app.cardinalhq.io)",
    )
    p.add_argument(
        "--telemetry-only", action="store_true",
        help="Skip the MCP side. Only the [otel] block + cardinal.json "
             "telemetry state are written; no MCP server is registered in "
             "~/.codex/config.toml.",
    )
    p.add_argument(
        "--no-tool-details", action="store_true",
        help="Opt out of capturing bash commands and file paths. NOTE: the "
             "Outcomes Dashboard will show repo=unknown and service=unknown "
             "without this — see the SKILL.md.",
    )
    p.add_argument(
        "--rotate", action="store_true",
        help="Proceed even if state shows we're already connected. Overwrites "
             "with freshly-minted keys. (Previous keys stay alive until their "
             "TTL or until /cardinal:disconnect.)",
    )
    p.add_argument(
        "--deployment-env", default=None,
        help="Override the derived deployment.environment label (prod / "
             "dogfood / cardinal / customer / unknown).",
    )
    p.add_argument(
        "--dry-run", action="store_true",
        help="Run the device-code flow and print what would be written; touch "
             "no files.",
    )
    args = p.parse_args()

    if STATE_PATH.exists() and not args.rotate:
        try:
            prior = json.loads(STATE_PATH.read_text())
        except Exception:
            prior = {}
        prior_user = prior.get("user_email") or "this account"
        sys.stderr.write(
            f"Cardinal is already connected as {prior_user}. "
            f"Re-run with --rotate to overwrite.\n"
        )
        return 2

    scopes = ["ingest:write"]
    if not args.telemetry_only:
        scopes.append("mcp:invoke")

    print(f"  Requesting consent for scopes: {', '.join(scopes)}")
    grant = start_device_code(args.host, scopes)
    expires_in = int(grant.get("expires_in") or DEFAULT_POLL_TIMEOUT_SECS)
    interval = int(grant.get("interval") or DEFAULT_POLL_INTERVAL_SECS)
    verification_uri = grant.get("verification_uri") or ""

    # Side-channel write so Codex can surface the URL while we block on the
    # poll loop below. Cleared in the finally regardless of success path.
    write_pending(grant)
    try:
        return _continue_after_grant(
            args, grant, expires_in, interval, verification_uri,
        )
    finally:
        clear_pending()


def _continue_after_grant(
    args, grant: dict, expires_in: int, interval: int, verification_uri: str,
) -> int:
    print()
    print("  Open this URL in your browser to approve:")
    print(f"    {verification_uri}")
    print()
    print(f"  (waiting up to {expires_in // 60} minute(s) for browser approval…)")

    bundle = poll_device_token(args.host, grant["device_code"], interval, expires_in)

    org = bundle.get("org", {})
    user = bundle.get("user", {})
    ingest = bundle.get("ingest")
    mcp = bundle.get("mcp")

    deployment_env = args.deployment_env or derive_deployment_env(args.host)
    capture_tool_details = not args.no_tool_details

    if args.dry_run:
        would_write_toml = []
        if ingest:
            would_write_toml.append("[otel]")
        if mcp:
            would_write_toml.append("[mcp_servers.cardinal]")
        print(json.dumps(
            {
                "org": org,
                "user": user,
                "deployment_env": deployment_env,
                "would_write": {
                    "state_file": str(STATE_PATH),
                    "config_toml_tables": would_write_toml,
                    "resource_attributes": (
                        build_resource_attributes(bundle, deployment_env)
                        if ingest else None
                    ),
                },
            },
            indent=2,
        ))
        return 0

    # Reachability sanity check (best-effort, before any writes).
    if ingest:
        ok, msg = verify_ingest_reachable(ingest["endpoint"], ingest["api_key"])
        if not ok:
            sys.exit(f"ingest reachability failed: {msg}")
        print(f"  ✓ Ingest endpoint reachable ({msg})")
    if mcp:
        mcp_header_name = mcp.get("api_header") or MCP_API_HEADER
        ok, msg = verify_mcp_reachable(mcp["url"], mcp["api_key"], mcp_header_name)
        if not ok:
            sys.exit(f"MCP reachability failed: {msg}")
        print(f"  ✓ MCP endpoint reachable ({msg})")

    # ---- State file (full key, 0600) -------------------------------------
    write_state(bundle, args.host, deployment_env, capture_tool_details, args.telemetry_only)
    print(f"  ✓ Wrote state to {STATE_PATH}")

    # ---- config.toml: [otel] (telemetry) ---------------------------------
    if ingest:
        header_name = ingest.get("api_header") or "x-cardinalhq-api-key"
        write_config_toml({
            "otel": _emit_otel_block(
                ingest["endpoint"], deployment_env, header_name, ingest["api_key"],
            ),
        })
        print(f"  ✓ Wrote [otel] block to {CONFIG_PATH}")

    # ---- config.toml: MCP server -----------------------------------------
    if mcp:
        mcp_header_name = mcp.get("api_header") or MCP_API_HEADER
        add_mcp_server(mcp["url"], mcp_header_name, mcp["api_key"])
        print(
            "  ✓ Registered cardinal MCP server "
            "(via [mcp_servers.cardinal] in config.toml)"
        )

    # ---- hooks --------------------------------------------------------------
    # Not registered here. Codex auto-registers the plugin's hooks/hooks.json
    # (tracked in config.toml as cardinal@<marketplace>:hooks/hooks.json), so
    # merging into ~/.codex/hooks.json would fire every event twice.

    print()
    print(f"  Connected as {user.get('email') or 'unknown'} ({org.get('slug') or org.get('id')})")
    if ingest:
        print(f"  Telemetry → {ingest['endpoint']}")
        tool_msg = "enabled" if capture_tool_details else "disabled — repo/service will read as 'unknown'"
        print(f"  Tool details: {tool_msg}")
    if mcp:
        print(f"  MCP       → {mcp['url']}")
        print("               (registered in ~/.codex/config.toml; auth via http_headers)")
    print()
    print("Start a new Codex thread so it picks up the new config.toml.")
    print("Then run /cardinal:status to verify.")
    return 0


if __name__ == "__main__":
    sys.exit(main())
